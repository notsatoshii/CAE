# Node
node_modules/
.next/
*.log
tsconfig.tsbuildinfo

# Env
.env
.env.local

# CAE runtime state (regenerated per run; not code)
# .cae/ has sub-exceptions: .cae/logs/.gitkeep must be tracked so the log dir exists
.cae/**
!.cae/logs/
!.cae/logs/.gitkeep
.cae/logs/*.jsonl
.planning/phases/*/tasks/
.planning/phases/*/CAE-SUMMARY.md
.planning/review/
.planning/herald/
.shift/state.json
.shift/arch/
.shift/research/

# Phase 13 audit artifacts (large, regenerable)
# shots/* ignores PNGs but allows .gitkeep (negation on dir/ won't unignore children)
.planning/phases/13-ui-ux-review-polish-loop/shots/*
!.planning/phases/13-ui-ux-review-polish-loop/shots/.gitkeep
.planning/phases/13-ui-ux-review-polish-loop/scripts/storage-state.json
.planning/phases/13-ui-ux-review-polish-loop/audit/working/

# Phase 14 runtime state (append-only logs + mutable registry, not source)
# Note: scheduled_tasks.json lives at REPO ROOT (/home/cae/ctrl-alt-elite/), not here.
# It is gitignored by the root .gitignore.
# The .cae/metrics/ directory needs to exist in fresh clones.
# .cae/** above blocks the whole dir; add exceptions using the same pattern as .cae/logs/.
!.cae/metrics/
!.cae/metrics/.gitkeep
.cae/metrics/*.jsonl
