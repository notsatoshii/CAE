# Required: generate with `openssl rand -hex 32`
AUTH_SECRET=

# Required: create at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Required (Phase 14 Plan 04): create at https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# RBAC role assignment — comma-separated email lists (case-insensitive, whitespace trimmed)
# Admin: full access including settings. Operator: can run tasks. Viewer: read-only (default).
ADMIN_EMAILS=
OPERATOR_EMAILS=

# Optional: lock Google SSO to a Google Workspace domain (e.g. diiant.com).
# Leave unset to allow any Google account.
# AUTH_GOOGLE_HOSTED_DOMAIN=

# Optional for local dev
AUTH_URL=http://localhost:3000

# --- Phase 10: Plan mode (Shift wrapper) ---
# Root directory scanned for Shift-managed projects. Each subdirectory
# containing a `.shift/state.json` file is surfaced on /plan. Default
# matches the host layout on cae. Override per-host if needed.
SHIFT_PROJECTS_HOME=/home/cae
