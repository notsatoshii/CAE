# Required: generate with `openssl rand -hex 32`
AUTH_SECRET=

# Required: create at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional for local dev
AUTH_URL=http://localhost:3000

# --- Phase 10: Plan mode (Shift wrapper) ---
# Root directory scanned for Shift-managed projects. Each subdirectory
# containing a `.shift/state.json` file is surfaced on /plan. Default
# matches the host layout on cae. Override per-host if needed.
SHIFT_PROJECTS_HOME=/home/cae
