#!/usr/bin/env python3
"""
CAE — Ctrl+Alt+Elite orchestrator (Phase 1 T7: real execution)

Usage:
  cae execute-phase <N> [--dry-run]   Execute phase N (default: real execution)
  cae version
  cae help

Reads:
  config/agent-models.yaml       (CAE repo: roles & model routing)
  config/circuit-breakers.yaml   (CAE repo: limits)
  .planning/config.json          (project CAE config)
  .planning/phases/<N>-*/PLAN.md (plans to execute)

Execution model:
  - Waves ordered by PLAN.md frontmatter `wave: N`
  - Within a wave: parallel up to circuit_breakers.max_concurrent_forge
  - Per task:
      1. acquire forge semaphore slot
      2. create forge/<task-id> branch
      3. spawn Claude adapter with Forge persona
      4. on success → Sentinel review (stub for now; real in T8)
      5. on Sentinel approve → merge branch with CAE_MERGE_TOKEN
      6. on Sentinel reject → retry (counts toward max_retries)
      7. after 3 Forge fails → Phantom escalation
      8. after 2 Phantom fails → halt + Telegram
  - Metrics logged to .cae/metrics/

Dry-run keeps the old behavior: prints the plan without touching git or CLIs.
"""
from __future__ import annotations

import concurrent.futures
import json
import os
import re
import subprocess
import sys
import time
import uuid
from pathlib import Path
from typing import List, Optional

VERSION = "0.2.0-T7"

# ─── Paths ──────────────────────────────────────────────────────────────
_THIS = Path(__file__).resolve()
CAE_ROOT = _THIS.parent.parent
AGENT_MODELS_PATH = CAE_ROOT / "config" / "agent-models.yaml"
CLAUDE_ADAPTER = CAE_ROOT / "adapters" / "claude-code.sh"
FORGE_BRANCH_SCRIPT = CAE_ROOT / "scripts" / "forge-branch.sh"

# Make sibling modules importable
sys.path.insert(0, str(_THIS.parent))
from circuit_breakers import CircuitBreakers, LimitExceeded  # noqa: E402
from phantom import Phantom  # noqa: E402


def die(msg, code=1):
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(code)


def load_yaml(path):
    try:
        import yaml
    except ImportError:
        die("PyYAML required")
    with open(path) as f:
        return yaml.safe_load(f)


# ─── Loading project state ──────────────────────────────────────────────
def load_planning_config(project_root):
    cfg_file = project_root / ".planning" / "config.json"
    if not cfg_file.exists():
        die(f"{cfg_file} not found — run /gsd-new-project then cae-init first")
    return json.loads(cfg_file.read_text())


def find_phase_dir(project_root, phase_num):
    phases_root = project_root / ".planning" / "phases"
    if not phases_root.is_dir():
        die(f"{phases_root} not found")
    padded = f"{int(phase_num):02d}"
    candidates = sorted(phases_root.glob(f"{padded}-*"))
    if not candidates:
        candidates = sorted(phases_root.glob(f"{phase_num}-*"))
    if not candidates:
        die(f"no phase directory found for phase {phase_num} in {phases_root}")
    return candidates[0]


def parse_plan_frontmatter(plan_path):
    content = plan_path.read_text()
    m = re.match(r"^---\n(.*?)\n---\n", content, re.DOTALL)
    if not m:
        return {}, content
    try:
        import yaml
        fm = yaml.safe_load(m.group(1)) or {}
    except Exception:
        fm = {}
    body = content[m.end():]
    return fm, body


def parse_tasks(body):
    tasks = []
    for m in re.finditer(r"<task[^>]*>(.*?)</task>", body, re.DOTALL):
        block = m.group(1)
        name_m = re.search(r"<name>(.*?)</name>", block, re.DOTALL)
        files_m = re.search(r"<files>(.*?)</files>", block, re.DOTALL)
        action_m = re.search(r"<action>(.*?)</action>", block, re.DOTALL)
        verify_m = re.search(r"<verify>(.*?)</verify>", block, re.DOTALL)
        tasks.append({
            "name": (name_m.group(1).strip() if name_m else "<unnamed task>"),
            "files": (files_m.group(1).strip() if files_m else ""),
            "action": (action_m.group(1).strip() if action_m else ""),
            "verify": (verify_m.group(1).strip() if verify_m else ""),
            "raw": block.strip(),
        })
    return tasks


def detect_smart_contract_mode(project_root):
    markers = ["*.sol", "*.vy", "foundry.toml", "hardhat.config.js",
               "hardhat.config.ts", "hardhat.config.cjs", "truffle-config.js",
               "remappings.txt"]
    for m in markers:
        for candidate in project_root.rglob(m):
            rel = candidate.relative_to(project_root)
            if any(p in str(rel) for p in ("node_modules", ".git", ".planning")):
                continue
            return True
    return False


def resolve_role(agent_models, role_name, sc_mode):
    role = agent_models.get(role_name)
    if role is None:
        die(f"role '{role_name}' not defined in agent-models.yaml")
    if "modes" in role:
        mode = role.get("default_mode")
        role = role["modes"].get(mode, {})
    model = role.get("model")
    if sc_mode and "smart_contract_override" in role:
        model = role["smart_contract_override"]
    aliases = {"opus": "claude-opus-4-6", "sonnet": "claude-sonnet-4-6", "haiku": "claude-haiku-4-5"}
    model = aliases.get(model, model)
    return {
        "model": model,
        "provider": role.get("provider", "unknown"),
        "invocation_mode": role.get("invocation_mode", {}),
        "effort": role.get("effort"),
        "fallback": role.get("fallback"),
    }


# ─── Execution primitives ───────────────────────────────────────────────
def build_forge_prompt(task: dict, plan_fm: dict, project_root: Path, phase_dir: Path) -> str:
    """Construct the user prompt Forge receives."""
    agents_md = ""
    am_path = project_root / "AGENTS.md"
    if am_path.exists():
        agents_md = f"- AGENTS.md (team conventions — read and apply)\n"

    return f"""<objective>
Phase {plan_fm.get('phase', '?')} Task: {task['name']}
</objective>

<task_spec>
{task['raw']}
</task_spec>

<files_to_read>
- {phase_dir.relative_to(project_root)}/{phase_dir.name}-PLAN.md (your plan)
{agents_md}- .planning/PROJECT.md (project context)
- .planning/STATE.md (current state)
</files_to_read>

<instructions>
Implement the task per the plan. Match AGENTS.md conventions.
Make ALL changes, then commit with a concise message.
When done, return a brief SUMMARY in this format:

## SUMMARY
- Changed: {{list of files}}
- Tests: {{passed/failed}}
- Notes: {{anything Sentinel or Scribe should know}}
</instructions>
"""


def spawn_forge(task_id: str, prompt_path: Path, model: str, system_prompt_file: Optional[str] = None, agent_wrap: Optional[str] = None, timeout: int = 1800) -> dict:
    """
    Invoke the Claude adapter. Returns dict with exit_code, output_path, error_path, meta.
    """
    cmd = [
        str(CLAUDE_ADAPTER),
        str(prompt_path),
        model,
        task_id,
        "--timeout", str(timeout),
    ]
    if agent_wrap:
        cmd.extend(["--agent", agent_wrap])
    elif system_prompt_file:
        cmd.extend(["--system-prompt-file", system_prompt_file])
    else:
        raise ValueError("Must specify either agent_wrap or system_prompt_file")

    result = subprocess.run(cmd, capture_output=False)
    output_path = Path(str(prompt_path) + ".output")
    error_path = Path(str(prompt_path) + ".error")
    meta_path = Path(str(prompt_path) + ".meta")

    meta = {}
    if meta_path.exists():
        try:
            meta = json.loads(meta_path.read_text())
        except Exception:
            pass

    return {
        "exit_code": result.returncode,
        "output_path": output_path,
        "error_path": error_path,
        "meta": meta,
        "output": output_path.read_text() if output_path.exists() else "",
    }


def _get_git_diff(project_root: Path, branch: str) -> str:
    """Get the diff of a forge branch vs main."""
    try:
        r = subprocess.run(["git", "-C", str(project_root), "diff", "main...HEAD"],
                          capture_output=True, text=True, timeout=10)
        if r.returncode == 0 and r.stdout:
            return r.stdout
    except Exception:
        pass
    return ""


def sentinel_review(task_id: str, plan_path: Path, branch: str, project_root: Path, builder_model: str, cb: CircuitBreakers) -> dict:
    """
    Real Sentinel review via bin/sentinel.py. Sentinel itself picks Gemini (if
    installed) or Claude gsd-verifier fallback. No auto-approve stub.
    """
    from sentinel import Sentinel
    diff = _get_git_diff(project_root, branch)
    s = Sentinel(project_root, cb)
    return s.review(task_id, plan_path, diff, builder_model)


def sentinel_review_stub(task_id: str, plan_path: Path, forge_output: str, project_root: Path, builder_model: str) -> dict:
    """DEPRECATED — kept for backwards compat. Use sentinel_review() instead."""
    return {
        "approve": True,
        "reviewer_model": "stub",
        "builder_model": builder_model,
        "issues": [],
        "_stub": True,
    }


def git_run(args: List[str], cwd: Path, env_extra: Optional[dict] = None) -> subprocess.CompletedProcess:
    env = os.environ.copy()
    if env_extra:
        env.update(env_extra)
    return subprocess.run(["git"] + args, cwd=cwd, capture_output=True, text=True, env=env)


def forge_branch(subcommand: str, task_id: str, project_root: Path, extra: List[str] = None) -> subprocess.CompletedProcess:
    cmd = ["bash", str(FORGE_BRANCH_SCRIPT), subcommand, task_id]
    if extra:
        cmd.extend(extra)
    return subprocess.run(cmd, cwd=project_root, capture_output=True, text=True)


# ─── Task execution with retry + Phantom ────────────────────────────────
def execute_one_task(
    task: dict,
    task_id: str,
    plan_fm: dict,
    plan_path: Path,
    phase_dir: Path,
    project_root: Path,
    forge_resolved: dict,
    cb: CircuitBreakers,
    phantom: Phantom,
) -> dict:
    """
    Execute a single task with full retry + Phantom loop.
    Returns dict: {success, task_id, attempts, final_status, branch, notes}
    """
    inv = forge_resolved["invocation_mode"]
    model = forge_resolved["model"]

    # Create forge branch
    br = forge_branch("create", task_id, project_root)
    if br.returncode != 0:
        return {"success": False, "task_id": task_id, "attempts": 0, "final_status": "branch_create_failed", "notes": br.stderr.strip()}

    branch = br.stdout.strip()

    # Prepare prompt file in .planning/phases/<N>/tasks/<task-id>/
    task_dir = phase_dir / "tasks" / task_id
    task_dir.mkdir(parents=True, exist_ok=True)
    prompt_path = task_dir / "task.md"
    prompt_path.write_text(build_forge_prompt(task, plan_fm, project_root, phase_dir))

    extra_fix_context = ""  # Fed back from Phantom on retries
    attempts = 0
    last_forge_output = ""

    while True:
        attempts += 1
        cb.begin_forge_run(task_id)

        # Re-write prompt if Phantom gave us fix context
        if extra_fix_context:
            augmented = prompt_path.read_text() + f"\n\n<retry_context>\nPrior attempts failed. Phantom's guidance:\n{extra_fix_context}\n</retry_context>\n"
            prompt_path.write_text(augmented)

        # Apply compaction cascade before spawning
        try:
            from compactor import Compactor
            Compactor(project_root, model=model).compact(prompt_path)
        except Exception as _e:
            pass  # Compaction is best-effort; don't fail the task if it errors

        # Spawn Forge
        try:
            with cb.acquire_forge_slot():
                kwargs = {"model": model, "timeout": 1800}
                if inv.get("type") == "wrap-gsd-agent":
                    kwargs["agent_wrap"] = inv["name"]
                else:
                    spf = inv.get("system_prompt_file", "")
                    kwargs["system_prompt_file"] = str(CAE_ROOT / spf) if spf else None
                forge_result = spawn_forge(task_id, prompt_path, **kwargs)
        except LimitExceeded as e:
            return {"success": False, "task_id": task_id, "attempts": attempts, "final_status": f"circuit_breaker:{e.limit_name}", "branch": branch, "notes": str(e)}

        forge_ok = forge_result["exit_code"] == 0
        last_forge_output = forge_result["output"]
        cb.record_forge_attempt(task_id, success=forge_ok)

        if not forge_ok:
            # Forge itself failed (not just a rejected review)
            if cb.should_escalate_to_phantom(task_id):
                # Phantom time
                forge_summaries = sorted(task_dir.glob("SUMMARY-*.md"))
                ph_result = phantom.investigate(
                    task_id, plan_path, forge_summaries,
                    git_diff="", error_output=forge_result.get("output", "") + "\n" + Path(str(prompt_path) + ".error").read_text() if Path(str(prompt_path) + ".error").exists() else "",
                )
                cb.record_phantom_attempt(task_id, success=(ph_result.kind in ("fix", "inline_done")))

                if ph_result.kind == "fix":
                    extra_fix_context = ph_result.fix_instructions or ""
                    # Loop back for another Forge attempt
                    continue
                elif ph_result.kind == "inline_done":
                    # Phantom says it's fixed — verify via Sentinel
                    pass
                else:
                    # Escalate or failed
                    forge_branch("abandon", task_id, project_root)
                    return {"success": False, "task_id": task_id, "attempts": attempts, "final_status": f"phantom_{ph_result.kind}", "branch": branch, "notes": (ph_result.report or "")[:500]}

                if cb.should_halt():
                    forge_branch("abandon", task_id, project_root)
                    return {"success": False, "task_id": task_id, "attempts": attempts, "final_status": "halt", "branch": branch, "notes": "Phantom exhausted"}
            elif attempts < cb.cfg.max_retries:
                # Plain retry without Phantom
                continue
            else:
                forge_branch("abandon", task_id, project_root)
                return {"success": False, "task_id": task_id, "attempts": attempts, "final_status": "forge_retry_exhausted", "branch": branch}

        # Save a SUMMARY for this attempt (Phantom uses these on escalation)
        summary_path = task_dir / f"SUMMARY-attempt{attempts}.md"
        summary_path.write_text(last_forge_output)

        # Sentinel review (stub until T8 lands)
        verdict = sentinel_review(task_id, plan_path, branch, project_root, model, cb)

        if verdict["approve"]:
            # Merge and return
            merge = forge_branch("merge", task_id, project_root, extra=["main"])
            if merge.returncode != 0:
                # Try inferring target
                merge2 = forge_branch("merge", task_id, project_root)
                if merge2.returncode != 0:
                    return {"success": False, "task_id": task_id, "attempts": attempts, "final_status": "merge_failed", "branch": branch, "notes": merge.stderr + merge2.stderr}
            return {"success": True, "task_id": task_id, "attempts": attempts, "final_status": "approved_and_merged", "branch": branch, "sentinel_stub": verdict.get("_stub", False)}

        # Rejected
        if attempts >= cb.cfg.max_retries:
            forge_branch("abandon", task_id, project_root)
            return {"success": False, "task_id": task_id, "attempts": attempts, "final_status": "sentinel_retry_exhausted", "branch": branch, "notes": "issues=" + str(verdict.get("issues"))}
        # Feed issues into next retry
        extra_fix_context = "Sentinel issues:\n" + json.dumps(verdict.get("issues", []), indent=2)
        continue


# ─── Wave orchestration ─────────────────────────────────────────────────
def execute_wave(
    wave_num: int,
    plans: list,
    phase_dir: Path,
    project_root: Path,
    agent_models: dict,
    sc_mode: bool,
    cb: CircuitBreakers,
    phantom: Phantom,
) -> List[dict]:
    """Run all tasks in a wave in parallel (bounded by circuit breaker)."""
    forge_resolved = resolve_role(agent_models, "forge", sc_mode)
    results = []
    jobs = []

    for plan_path, plan_fm, plan_body in plans:
        tasks = parse_tasks(plan_body)
        for i, task in enumerate(tasks, 1):
            task_id = f"p{plan_fm.get('phase', '?')}-pl{plan_fm.get('plan', 'X')}-t{i}-{uuid.uuid4().hex[:6]}"
            jobs.append((task, task_id, plan_fm, plan_path))

    max_workers = cb.cfg.max_concurrent_forge
    print(f"  Running {len(jobs)} tasks (up to {max_workers} parallel)...")

    with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as pool:
        futures = {
            pool.submit(execute_one_task, task, tid, fm, ppath, phase_dir, project_root, forge_resolved, cb, phantom): tid
            for (task, tid, fm, ppath) in jobs
        }
        for fut in concurrent.futures.as_completed(futures):
            r = fut.result()
            results.append(r)
            status_mark = "✓" if r["success"] else "✗"
            print(f"    {status_mark} {r['task_id']}: {r['final_status']} (attempts={r['attempts']})")

    return results


# ─── Commands ───────────────────────────────────────────────────────────
def cmd_execute_phase(phase_num: str, dry_run: bool = False):
    project_root = Path.cwd()
    pcfg = load_planning_config(project_root)
    agent_models = load_yaml(AGENT_MODELS_PATH)
    sc_mode = detect_smart_contract_mode(project_root)
    phase_dir = find_phase_dir(project_root, phase_num)

    plan_files = sorted(phase_dir.glob("*-PLAN.md"))
    if not plan_files:
        if (phase_dir / "PLAN.md").exists():
            plan_files = [phase_dir / "PLAN.md"]
        else:
            die(f"no *-PLAN.md files found in {phase_dir}")

    # Group by wave
    waves = {}
    for pf in plan_files:
        fm, body = parse_plan_frontmatter(pf)
        wave = fm.get("wave", 1)
        waves.setdefault(wave, []).append((pf, fm, body))

    print(f"CAE execute-phase {phase_num}  (dry-run={dry_run})")
    print(f"  Project: {project_root}")
    print(f"  Phase dir: {phase_dir.relative_to(project_root)}")
    print(f"  Smart contract mode: {'YES' if sc_mode else 'no'}")
    print(f"  Waves: {len(waves)}")
    print()

    if dry_run:
        _dry_run_print(waves, agent_models, sc_mode, phase_num)
        return

    # Initialize CB + Phantom
    cb = CircuitBreakers.load(project_root)
    phantom = Phantom(project_root, cb)

    # Install branch guard if not already
    guard_installer = CAE_ROOT / "scripts" / "install-branch-guard.sh"
    subprocess.run(["bash", str(guard_installer), str(project_root)], check=False)

    all_results = []
    for wave_num in sorted(waves.keys()):
        print(f"━━ Wave {wave_num} ━━")
        plans = waves[wave_num]
        wave_results = execute_wave(wave_num, plans, phase_dir, project_root, agent_models, sc_mode, cb, phantom)
        all_results.extend(wave_results)
        if any(not r["success"] for r in wave_results):
            print(f"  ⚠ Wave {wave_num} had failures; not proceeding to next wave without manual review")
            break
        if cb.should_halt():
            print(f"  ⚠ Circuit breakers halted execution")
            break

    print()
    print("━━ Phase summary ━━")
    ok = sum(1 for r in all_results if r["success"])
    fail = len(all_results) - ok
    print(f"  Tasks: {ok} succeeded, {fail} failed")

    # Post-phase Scribe (runs if any task succeeded — Gemini Flash if installed, else Claude Haiku)
    if ok > 0:
        try:
            from scribe import Scribe
            print(f"  Running Scribe on phase {phase_num}...")
            applied = Scribe(project_root).run_for_phase(phase_num)
            if "error" in applied:
                print(f"  ⚠ Scribe: {applied['error']}")
            else:
                print(f"  Scribe: +{applied.get('agents_md_added', 0)} AGENTS.md entries, {applied.get('knowledge_topics_updated', 0)} KNOWLEDGE topics")
        except Exception as e:
            print(f"  ⚠ Scribe failed: {e}")

    # Write phase summary file
    summary_path = phase_dir / "CAE-SUMMARY.md"
    with open(summary_path, "w") as f:
        f.write(f"# CAE Phase {phase_num} Execution Summary\n\n")
        f.write(f"**Run:** {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())}\n")
        f.write(f"**Tasks:** {ok} succeeded, {fail} failed\n\n")
        for r in all_results:
            mark = "✓" if r["success"] else "✗"
            f.write(f"- {mark} `{r['task_id']}` — {r['final_status']} (attempts={r['attempts']})\n")

    sys.exit(0 if fail == 0 else 1)


def _dry_run_print(waves, agent_models, sc_mode, phase_num):
    forge_resolved = resolve_role(agent_models, "forge", sc_mode)
    total_tasks = 0
    for wave_num in sorted(waves.keys()):
        print(f"━━ Wave {wave_num} ━━")
        for pf, fm, body in waves[wave_num]:
            tasks = parse_tasks(body)
            print(f"  Plan: {pf.name}  tasks={len(tasks)}")
            for i, t in enumerate(tasks, 1):
                inv = forge_resolved["invocation_mode"]
                inv_desc = f"wrap:{inv.get('name')}" if inv.get("type") == "wrap-gsd-agent" else f"direct:{inv.get('system_prompt_file', '').split('/')[-1]}"
                print(f"    Task {i}: {t['name'][:60]}")
                print(f"      model={forge_resolved['model']}  invocation={inv_desc}")
                total_tasks += 1
        print()
    sent = resolve_role(agent_models, "sentinel", sc_mode)
    print(f"━━ After each wave: Sentinel ━━")
    print(f"  model={sent['model']}  provider={sent['provider']}  (T8 wires real; currently stub)")
    print()
    print(f"Total: {total_tasks} tasks across {len(waves)} waves")


def cmd_banner():
    banner_path = CAE_ROOT / "assets" / "banner.txt"
    if banner_path.exists():
        print(banner_path.read_text())


def cmd_help():
    print(__doc__.strip())


def main():
    argv = sys.argv[1:]
    if not argv:
        cmd_banner()
        print()
        cmd_help()
        return
    if argv[0] in ("banner",):
        cmd_banner()
        return
    if argv[0] in ("-h", "--help", "help"):
        cmd_help()
        return
    if argv[0] in ("-v", "--version", "version"):
        print(f"cae {VERSION}")
        return
    if argv[0] == "execute-phase":
        if len(argv) < 2:
            die("usage: cae execute-phase <phase-number> [--dry-run]")
        phase = argv[1]
        dry = "--dry-run" in argv[2:]
        cmd_execute_phase(phase, dry_run=dry)
        return
    if argv[0] == "herald":
        if len(argv) < 2:
            die("usage: cae herald <doc-type> [--fast|--plan|--review <file>] [--auto]\n"
                "  doc-type = readme|architecture|deployment|changelog|custom\n"
                "  default : propose outline → user approve → write → sentinel review → iterate\n"
                "  --fast  : skip gates, one-shot (v0.1 behavior)\n"
                "  --plan  : only propose outline, stop\n"
                "  --review <file> : Sentinel-review existing doc, report issues\n"
                "  --auto  : skip interactive user gates, auto-approve outline + merge")
        cmd_herald(argv[1], argv[2:])
        return
    die(f"unknown command: {argv[0]}")


# ───────────────────────────────────────────────────────────────────────
# HERALD v0.2 — plan + review loops with user gates
# ───────────────────────────────────────────────────────────────────────

HERALD_TARGET_MAP = {
    "readme":       "README.md",
    "architecture": "ARCHITECTURE.md",
    "deployment":   "DEPLOYMENT.md",
    "changelog":    "CHANGELOG.md",
}


def _herald_config(project_root: Path):
    """Load herald + sentinel_fallback config; validate."""
    agent_models = load_yaml(AGENT_MODELS_PATH)
    herald = agent_models.get("herald")
    if herald is None:
        die("herald role not found in config/agent-models.yaml")
    fallback = agent_models.get("sentinel_fallback", {})
    return herald, fallback


def _herald_session_dir(project_root: Path, doc_type: str) -> Path:
    session_id = f"herald-{doc_type}-{uuid.uuid4().hex[:6]}"
    work_dir = project_root / ".planning" / "herald" / session_id
    work_dir.mkdir(parents=True, exist_ok=True)
    return work_dir


def _herald_spawn(prompt_path: Path, herald_cfg: dict, session_id: str) -> int:
    inv = herald_cfg["invocation_mode"]
    if inv.get("type") != "wrap-gsd-agent":
        die(f"herald invocation_mode must be wrap-gsd-agent; got {inv.get('type')}")
    cmd = [
        str(CLAUDE_ADAPTER),
        str(prompt_path),
        herald_cfg["model"],
        session_id,
        "--agent", inv["name"],
        "--effort", herald_cfg.get("effort", "max"),
        "--timeout", "1800",
    ]
    return subprocess.run(cmd, capture_output=False).returncode


def _herald_persona() -> str:
    p = CAE_ROOT / "agents" / "cae-herald.md"
    return p.read_text() if p.exists() else ""


def _herald_context(project_root: Path, target_file: Optional[str]) -> dict:
    existing = ""
    if target_file and (project_root / target_file).exists():
        existing = (project_root / target_file).read_text()[:8000]
    agents_md = ""
    if (project_root / "AGENTS.md").exists():
        agents_md = (project_root / "AGENTS.md").read_text()[:3000]
    return {"existing": existing, "agents_md": agents_md}


def _herald_ask_user(prompt_text: str, auto: bool, default: str = "y") -> bool:
    """Interactive yes/no gate. Returns True for yes/approve. --auto returns True always."""
    if auto:
        return True
    try:
        reply = input(f"{prompt_text} [y/N]: ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        return False
    return reply in ("y", "yes")


def _herald_plan(doc_type: str, target_file: Optional[str], project_root: Path, work_dir: Path, herald_cfg: dict) -> Optional[str]:
    """Stage 1: ask Herald to propose a section outline, save to HERALD-PLAN.md."""
    ctx = _herald_context(project_root, target_file)
    session_id = work_dir.name + "-plan"
    prompt_path = work_dir / "plan-prompt.md"
    prompt_path.write_text(f"""<persona>
{_herald_persona()}
</persona>

<task>
Propose a section-level outline for `{target_file or '<to-be-named>'}` ({doc_type}).
DO NOT write the full doc. Only propose:
  1. Section headings (in order)
  2. One-line purpose per section
  3. Key facts/commits/files each section should reference (grep the code first)
  4. Estimated line count per section (target ≤300 total)
Write your output to `{work_dir / 'HERALD-PLAN.md'}`.
</task>

<project_root>{project_root}</project_root>
<existing_doc>
{ctx['existing'] or '(none)'}
</existing_doc>
<team_knowledge>
{ctx['agents_md'] or '(none)'}
</team_knowledge>

<instructions>
Scan the codebase briefly (README, bin/, config/, recent git log) to ground section
ideas in real structure. Then write HERALD-PLAN.md. Be concrete — name real files,
real commits, real features. No marketing fluff. Print "PLAN WRITTEN" when done.
</instructions>
""")
    print(f"Herald: proposing outline for {target_file or doc_type}...")
    rc = _herald_spawn(prompt_path, herald_cfg, session_id)
    plan_path = work_dir / "HERALD-PLAN.md"
    if plan_path.exists():
        return plan_path.read_text()
    out = Path(str(prompt_path) + ".output")
    if out.exists():
        return out.read_text()
    return None


def _herald_write(doc_type: str, target_file: str, approved_outline: str, project_root: Path, work_dir: Path, herald_cfg: dict) -> int:
    """Stage 2: Herald writes the full doc per approved outline."""
    ctx = _herald_context(project_root, target_file)
    session_id = work_dir.name + "-write"
    prompt_path = work_dir / "write-prompt.md"
    prompt_path.write_text(f"""<persona>
{_herald_persona()}
</persona>

<task>
Write `{target_file}` for this project per the APPROVED OUTLINE below.
Every factual claim must be grep-verifiable against the current codebase.
</task>

<approved_outline>
{approved_outline}
</approved_outline>

<project_root>{project_root}</project_root>
<existing_doc>
{ctx['existing'] or '(none — produce from scratch)'}
</existing_doc>
<team_knowledge>
{ctx['agents_md'] or '(none)'}
</team_knowledge>

<instructions>
Write the doc to `{target_file}`. Follow the approved outline sections. Verify
every file path, function name, command, and version number against the live
code. Mark planned-not-built items clearly. When done, print "WRITE DONE" with
a brief change summary.
</instructions>
""")
    print(f"Herald: writing {target_file}...")
    return _herald_spawn(prompt_path, herald_cfg, session_id)


def _herald_review(doc_path: Path, project_root: Path, work_dir: Path, fallback_cfg: dict) -> Optional[dict]:
    """Stage 3: Sentinel-style review — fact-check every claim in the doc against actual code."""
    if not doc_path.exists():
        return None
    doc_text = doc_path.read_text()
    session_id = work_dir.name + "-review"
    prompt_path = work_dir / "review-prompt.md"
    prompt_path.write_text(f"""<task>
Fact-check this document against the actual codebase at `{project_root}`.
Look for:
  • Hallucinated file paths, function names, config keys, version numbers
  • Aspirational claims stated as present-tense fact
  • Internal contradictions
  • Missing honest-status markers for planned-not-built features
Produce a JSON verdict with this exact shape:
{{
  "verdict": "pass" | "fail",
  "issues": [
    {{"severity": "CRITICAL|MAJOR|MINOR", "claim": "...", "problem": "...", "fix": "..."}}
  ]
}}
</task>

<doc_to_review>
{doc_text[:20000]}
</doc_to_review>

<instructions>
Use Read/Grep/Glob to verify. Be strict — prefer flagging false positives over
missing real hallucinations. Return ONLY the JSON verdict at the end. "pass" means
zero CRITICAL or MAJOR issues.
</instructions>
""")
    print(f"Herald: Sentinel reviewing {doc_path.name}...")
    # Use sentinel_fallback (Claude Opus gsd-verifier) for adversarial review
    inv = fallback_cfg.get("invocation_mode", {})
    agent = inv.get("name", "gsd-verifier")
    model = fallback_cfg.get("model", "claude-opus-4-6")
    cmd = [str(CLAUDE_ADAPTER), str(prompt_path), model, session_id,
           "--agent", agent, "--effort", "max", "--timeout", "1800"]
    subprocess.run(cmd, capture_output=False)
    out = Path(str(prompt_path) + ".output")
    if not out.exists():
        return None
    raw = out.read_text()
    # Extract JSON
    start = raw.find("{")
    if start < 0:
        return None
    depth = 0
    for i in range(start, len(raw)):
        if raw[i] == "{": depth += 1
        elif raw[i] == "}":
            depth -= 1
            if depth == 0:
                try:
                    return json.loads(raw[start:i+1])
                except json.JSONDecodeError:
                    return None
    return None


def _herald_revise(doc_path: Path, issues: list, project_root: Path, work_dir: Path, herald_cfg: dict) -> int:
    """Stage 4: Herald revises the doc to address review issues."""
    session_id = work_dir.name + f"-revise-{uuid.uuid4().hex[:4]}"
    prompt_path = work_dir / f"revise-prompt-{session_id[-4:]}.md"
    issues_text = "\n".join(f"- [{i.get('severity','?')}] {i.get('claim','?')}\n  problem: {i.get('problem','?')}\n  fix: {i.get('fix','?')}" for i in issues)
    prompt_path.write_text(f"""<persona>
{_herald_persona()}
</persona>

<task>
Fix the issues below in `{doc_path}`. Re-read the file, fix each issue, and write
the corrected version back to the same path. Verify fixes don't introduce new
hallucinations. Print "REVISE DONE" when finished.
</task>

<review_issues>
{issues_text}
</review_issues>

<project_root>{project_root}</project_root>
""")
    print(f"Herald: revising {doc_path.name} ({len(issues)} issues)...")
    return _herald_spawn(prompt_path, herald_cfg, session_id)


def cmd_herald(doc_type: str, extra_args: List[str]):
    """
    v0.2: propose outline → user approve → write → sentinel review → iterate.
    Flags: --fast (v0.1 one-shot), --plan (outline only), --review <file>, --auto (skip gates)
    """
    project_root = Path.cwd()
    herald_cfg, fallback_cfg = _herald_config(project_root)

    # Flag parsing
    fast = "--fast" in extra_args
    plan_only = "--plan" in extra_args
    auto = "--auto" in extra_args
    review_target = None
    if "--review" in extra_args:
        i = extra_args.index("--review")
        if i + 1 < len(extra_args):
            review_target = extra_args[i + 1]

    target_file = HERALD_TARGET_MAP.get(doc_type.lower())
    if target_file is None and doc_type.lower() != "custom":
        die(f"unknown doc-type '{doc_type}'. Supported: {', '.join(HERALD_TARGET_MAP.keys())} | custom")

    # ─── --review mode: Sentinel-review an existing doc, report, exit ──
    if review_target:
        doc_path = (project_root / review_target).resolve()
        if not doc_path.exists():
            die(f"review target not found: {doc_path}")
        work_dir = _herald_session_dir(project_root, doc_type + "-review")
        verdict = _herald_review(doc_path, project_root, work_dir, fallback_cfg)
        if verdict is None:
            die("review failed — no JSON verdict from Sentinel")
        print(f"\n━━ HERALD REVIEW — {doc_path.name} ━━")
        print(f"Verdict: {verdict.get('verdict', '?').upper()}")
        issues = verdict.get("issues", [])
        if not issues:
            print("No issues found.")
        else:
            for i, iss in enumerate(issues, 1):
                print(f"  {i}. [{iss.get('severity','?')}] {iss.get('claim','?')}")
                print(f"     problem: {iss.get('problem','?')}")
                print(f"     fix:     {iss.get('fix','?')}")
        review_md = work_dir / "HERALD-REVIEW.md"
        review_md.write_text(json.dumps(verdict, indent=2))
        print(f"\nFull report: {review_md}")
        sys.exit(0)

    # ─── --fast mode: v0.1 one-shot behavior (keep existing flow) ──────
    if fast:
        work_dir = _herald_session_dir(project_root, doc_type)
        ctx = _herald_context(project_root, target_file)
        prompt_path = work_dir / "herald-prompt.md"
        prompt_path.write_text(f"""<persona>
{_herald_persona()}
</persona>

<objective>
Produce or update `{target_file or '<ask user>'}` for this project.
Doc-type: {doc_type}. One-shot mode.
</objective>

<project_root>{project_root}</project_root>
<existing_doc>
{ctx['existing'] or '(none)'}
</existing_doc>
<team_knowledge>
{ctx['agents_md'] or '(none)'}
</team_knowledge>

<instructions>
You are Herald (persona above). Verify claims against the actual code.
Write to {target_file or 'the agreed filename'}. Print a brief SUMMARY when done.
</instructions>
""")
        print(f"Herald --fast spawning ({doc_type}) → {target_file or '<custom>'}")
        sys.exit(_herald_spawn(prompt_path, herald_cfg, work_dir.name))

    # ─── Default: plan → approve → write → review → revise loop ────────
    work_dir = _herald_session_dir(project_root, doc_type)

    # Stage 1: Plan
    plan = _herald_plan(doc_type, target_file, project_root, work_dir, herald_cfg)
    if plan is None:
        die("plan stage failed — no HERALD-PLAN.md produced")
    print("\n━━ HERALD OUTLINE ━━")
    print(plan[:2500] + ("\n... (truncated)" if len(plan) > 2500 else ""))
    print("━━━━━━━━━━━━━━━━━━━━")

    if plan_only:
        print(f"\nPlan saved: {work_dir / 'HERALD-PLAN.md'}")
        sys.exit(0)

    if not _herald_ask_user("Approve this outline and proceed to write?", auto):
        print("Aborted. Outline saved for your review; re-run with --fast or adjust and re-run.")
        sys.exit(1)

    # Stage 2: Write
    if target_file is None:
        die("--custom requires a target filename; not yet implemented for default flow (use --fast)")
    rc = _herald_write(doc_type, target_file, plan, project_root, work_dir, herald_cfg)
    doc_path = project_root / target_file
    if rc != 0 or not doc_path.exists():
        die(f"write stage failed (rc={rc}) — check {work_dir}")

    # Stage 3 + 4: Review + revise loop (max 2 revise rounds)
    for round_num in range(1, 3):
        verdict = _herald_review(doc_path, project_root, work_dir, fallback_cfg)
        if verdict is None:
            print(f"⚠ review round {round_num}: Sentinel produced no verdict — stopping loop")
            break
        issues = verdict.get("issues", [])
        blocking = [i for i in issues if i.get("severity", "").upper() in ("CRITICAL", "MAJOR")]
        print(f"\n━━ HERALD REVIEW (round {round_num}) ━━")
        print(f"Verdict: {verdict.get('verdict','?').upper()} ({len(issues)} issues, {len(blocking)} blocking)")
        for i, iss in enumerate(issues[:10], 1):
            print(f"  {i}. [{iss.get('severity','?')}] {iss.get('claim','?')[:100]}")
        if verdict.get("verdict", "").lower() == "pass" and not blocking:
            print("✓ Doc passes Sentinel review.")
            break
        if not _herald_ask_user(f"Revise {target_file} to fix these issues?", auto):
            print("Skipping revise; doc left as-is.")
            break
        _herald_revise(doc_path, issues, project_root, work_dir, herald_cfg)

    print(f"\nHerald done. Doc: {doc_path}\nAudit trail: {work_dir}")
    sys.exit(0)


if __name__ == "__main__":
    main()
